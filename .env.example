# ============================
# パッティング分析システム 環境変数設定
# ============================
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# ----------------------------
# Supabase 設定
# https://supabase.com → プロジェクト設定 → API
# ----------------------------

# Supabase プロジェクト URL（例: https://xxxxxxxxxxxx.supabase.co）
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key（サーバー側のみ使用。公開しないこと）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase ストレージバケット名（デフォルト: scorecards）
SUPABASE_STORAGE_BUCKET=scorecards

# ----------------------------
# フロントエンド公開変数（EXPO_PUBLIC_ プレフィックスが必要）
# ----------------------------

# Supabase 公開 URL（フロントエンドから使用）
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key（フロントエンドから使用）
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API サーバーのベース URL（フロントエンドから使用）
# 本番環境: 空白（同一オリジンの /api/trpc を相対参照）
# ローカル開発(Web): http://localhost:3000 必須（空白だと Metro:8081 に飛んで 404 になる）
# スマホ実機: http://<MacのLAN IP>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ----------------------------
# Google AI Studio (Gemini)
# https://aistudio.google.com/app/apikey
# ----------------------------

GEMINI_API_KEY=your-gemini-api-key

# OCRに使うGeminiモデル（省略時: gemini-3.1-flash-lite = 安定版・低コスト）
# gemini-3.5-flash: 高精度・高コスト（$1.50/$9.00 per 1M tokens）
# ※gemini-2.5系は2026/10/16に廃止予定のため使用しない
# GEMINI_MODEL=gemini-3.1-flash-lite

# ----------------------------
# データベース設定（Supabase PostgreSQL）
# Supabase → プロジェクト設定 → Database → Connection string
# ----------------------------

DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ----------------------------
# その他
# ----------------------------

# セッション Cookie 署名用シークレット（32文字以上のランダム文字列）
JWT_SECRET=your-very-long-random-secret-string

# 管理者ユーザーの Supabase UUID（Supabase Auth → Users で確認）
OWNER_OPEN_ID=your-supabase-user-uuid

# サーバーポート（デフォルト: 3000）
PORT=3000
